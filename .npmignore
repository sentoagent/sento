# Plugin transient state — these get created on the user's machine when the
# plugin first launches (`bun install` inside the plugin dir), and during
# local dev when we test the plugins. Never publish them.
plugins/*/node_modules/
plugins/*/bun.lock
plugins/*/.env

# Standard exclusions — npm already handles most of these by default but
# being explicit avoids accidents
.git/
.github/
.vscode/
.idea/
*.log
.DS_Store
Thumbs.db

# Dev/test
test/
__tests__/
*.test.js
*.spec.js
.eslintrc*
.prettierrc*
